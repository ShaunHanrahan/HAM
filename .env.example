# Get a free API key at https://www.n2yo.com/api/  (register, then your key appears in your account)
N2YO_API_KEY=PASTE_YOUR_KEY_HERE

# Optional: use your own n2yo-compatible API server instead of n2yo.com.
# When this is set, no API key is needed and n2yo's rate limits don't apply.
# N2YO_BASE=http://sattrackapi:8000/rest/v1/satellite

# Optional: port for the local server (default 10489)
PORT=10489
